{
  "manifest_version": 3,
  "name": "Acuity | Narrative Integrity Engine",
  "version": "1.0.13",
  "description": "Forensic linguistic analysis. Detects emotional coercion, logical fallacies, and citation integrity in news articles.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Analyze with Acuity"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
