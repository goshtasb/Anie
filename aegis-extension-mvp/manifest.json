{
  "manifest_version": 3,
  "name": "Anie | Narrative Integrity Engine",
  "version": "1.0.0",
  "description": "AI-powered psyop detection. Analyzes news for manipulation, fabricated authority, and emotional coercion.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Scan with Anie"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}